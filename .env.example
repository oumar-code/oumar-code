# ─────────────────────────────────────────────────────────────
#  .env.example — copy to .env and fill in your secrets
#  Never commit .env to version control
# ─────────────────────────────────────────────────────────────

# Model endpoint (OpenAI-compatible)
MODEL_ENDPOINT=https://api.example.com/v1/chat/completions

# API key for the endpoint above
MODEL_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model identifier
MODEL_NAME=qwen/qwen2.5-7b-instruct

# Active challenge (arm-create | backblaze-genblaze | qwen-cloud | demo)
CHALLENGE=demo

# Active profile (safe | aggressive)
PROFILE=safe

# Benchmark cost estimation (USD per 1K tokens)
COST_PER_1K_TOKENS=0.002

# Demo UI port
UI_PORT=7860

# Optional: Backblaze B2 credentials (for backblaze-genblaze challenge)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# Optional: observability
LOG_LEVEL=INFO
