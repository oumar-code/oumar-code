# OpenAI Fashion — Aggressive Profile Config
# Higher creativity settings for design generation

MODEL_NAME=gpt-5.6-luna
MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
MAX_TOKENS=2048
TEMPERATURE=0.9
BATCH_SIZE=2
TIMEOUT_SECONDS=90
COST_PER_1K_TOKENS=0.003

# Fashion-specific settings
FASHION_OFFLINE_FIRST=true
FASHION_SKILL_TRACKING=true
FASHION_GALLERY_MOCK=false
UI_PORT=3000
