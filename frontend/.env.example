# Aku Fashion — Frontend Environment Variables
# Copy to .env.local and fill in your keys

# OpenAI API key — required for live AI features
# Without this, the app runs in stub/demo mode (still fully functional)
OPENAI_API_KEY=sk-your-key-here

# Optional: override the default model
# MODEL_NAME=gpt-4o

# Next.js public URL (for production deployments)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
